# ============================================================
# claude-code-quota-monitor 统一环境变量模板
# ============================================================

# ---------- 必填：PostgreSQL 连接串 ----------
# Docker 部署建议使用容器名（示例）
MONITOR_DSN=postgresql://postgres:your-password@claude-code-hub-db-3gct:5432/claude_code_hub

# ---------- 必填：管理员登录密码 ----------
MONITOR_ADMIN_PASSWORD=please-change-me

# ---------- 可选：PostgreSQL 数据源 ----------
MONITOR_PROVIDER_SCHEMA=public
MONITOR_PROVIDER_TABLE=providers

# ---------- 可选：缓存 ----------
MONITOR_CACHE_TTL_MS=60000
MONITOR_RESULT_CACHE_TTL_SEC=604800
MONITOR_REDIS_URL=
MONITOR_REDIS_TLS_REJECT_UNAUTHORIZED=true

# ---------- 可选：代理 ----------
MONITOR_PROXY_URL=

# ---------- 可选：调试 ----------
MONITOR_LOG_LEVEL=info
MONITOR_DEBUG_HTTP=false

# ---------- Docker 可选：镜像与容器 ----------
IMAGE_NAME=ghcr.io/hashmapw/claude-code-hub-quota-monitor
IMAGE_TAG=latest
CONTAINER_NAME=claude-code-hub-quota-monitor
NODE_IMAGE=public.ecr.aws/docker/library/node:22-bookworm-slim

# ---------- Docker 可选：网络端口 ----------
HOST_BIND_IP=127.0.0.1
HOST_PORT=23010
CONTAINER_PORT=3010
# Docker 外部网络名称（需提前创建）
HUB_EXTERNAL_NETWORK=claude-code-hub-net-3gct

# ---------- Docker 可选：数据卷 ----------
# 默认使用仓库内 data 目录
DATA_SOURCE=./data
MONITOR_SETTINGS_DB_PATH=/app/data/provider-settings.sqlite
# 可选：把宿主机已有的 SQLite 数据库作为种子导入容器
SQLITE_SEED_ROOT=.
MONITOR_SQLITE_SEED_PATH=/app-seed/provider-settings.sqlite
# skip | if-missing | overwrite
MONITOR_SQLITE_IMPORT_MODE=if-missing
# 使用宿主机目录挂载时填写绝对路径（Linux 示例）
# DATA_SOURCE=/home/ubuntu/claude-quota-monitor-data
